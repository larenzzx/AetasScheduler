// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Team {
  ALABANG
  ZAMBOANGA
}

enum DayOfWeek {
  MON
  TUE
  WED
  THU
  FRI
  SAT
  SUN
}

model Employee {
  id          String          @id @default(cuid())
  name        String
  employeeId  String          @unique
  team        Team
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  schedules   ScheduleEntry[]
}

model ShiftType {
  id         String          @id @default(cuid())
  name       String          @unique
  startTime  String?         // e.g. "08:00 AM" or "6:00 AM", nullable for LEAVE / DAY-OFF / ADJUST
  endTime    String?         // e.g. "05:00 PM" or "3:00 PM", nullable
  colorHex   String          // e.g. "#808080" for gray
  isRotating Boolean         @default(false)
  sortOrder  Int             @default(0)
  schedules  ScheduleEntry[]
}

model ScheduleWeek {
  id            String          @id @default(cuid())
  weekStartDate DateTime        // Monday
  weekEndDate   DateTime        // Sunday
  team          Team
  label         String          // e.g. "June 15–21"
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  entries       ScheduleEntry[]

  @@unique([weekStartDate, team])
}

model ScheduleEntry {
  id             String       @id @default(cuid())
  employeeId     String
  employee       Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  scheduleWeekId String
  scheduleWeek   ScheduleWeek @relation(fields: [scheduleWeekId], references: [id], onDelete: Cascade)
  dayOfWeek      DayOfWeek
  shiftTypeId    String?      // null indicates "DAY-OFF"
  shiftType      ShiftType?   @relation(fields: [shiftTypeId], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([employeeId, scheduleWeekId, dayOfWeek])
}
